<?xml version="1.0"?>
<robot name="four_wheel_car">
  <link name="base_link">
    <visual><geometry><box size="0.4 0.3 0.1"/></geometry><material name="blue"><color rgba="0 0 1 1"/></material></visual>
    <collision><geometry><box size="0.4 0.3 0.1"/></geometry></collision>
    <inertial><mass value="2.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.03"/></inertial>
  </link>
  <link name="lf_w"><visual><geometry><cylinder length="0.04" radius="0.05"/></geometry></visual><collision><geometry><cylinder length="0.04" radius="0.05"/></geometry></collision><inertial><mass value="0.2"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial></link>
  <joint name="lf_j" type="continuous"><parent link="base_link"/><child link="lf_w"/><origin xyz="0.15 0.17 -0.05" rpy="-1.57 0 0"/><axis xyz="0 0 1"/></joint>
  <link name="rf_w"><visual><geometry><cylinder length="0.04" radius="0.05"/></geometry></visual><collision><geometry><cylinder length="0.04" radius="0.05"/></geometry></collision><inertial><mass value="0.2"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial></link>
  <joint name="rf_j" type="continuous"><parent link="base_link"/><child link="rf_w"/><origin xyz="0.15 -0.17 -0.05" rpy="-1.57 0 0"/><axis xyz="0 0 1"/></joint>
  <link name="lb_w"><visual><geometry><cylinder length="0.04" radius="0.05"/></geometry></visual><collision><geometry><cylinder length="0.04" radius="0.05"/></geometry></collision><inertial><mass value="0.2"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial></link>
  <joint name="lb_j" type="continuous"><parent link="base_link"/><child link="lb_w"/><origin xyz="-0.15 0.17 -0.05" rpy="-1.57 0 0"/><axis xyz="0 0 1"/></joint>
  <link name="rb_w"><visual><geometry><cylinder length="0.04" radius="0.05"/></geometry></visual><collision><geometry><cylinder length="0.04" radius="0.05"/></geometry></collision><inertial><mass value="0.2"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial></link>
  <joint name="rb_j" type="continuous"><parent link="base_link"/><child link="rb_w"/><origin xyz="-0.15 -0.17 -0.05" rpy="-1.57 0 0"/><axis xyz="0 0 1"/></joint>
  <gazebo>
    <plugin name="skid_steer" filename="libgazebo_ros_diff_drive.so">
      <ros><remapping>cmd_vel:=cmd_vel</remapping></ros>
      <num_wheel_pairs>2</num_wheel_pairs>
      <left_joint>lf_j</left_joint><left_joint>lb_j</left_joint>
      <right_joint>rf_j</right_joint><right_joint>rb_j</right_joint>
      <wheel_separation>0.34</wheel_separation><wheel_diameter>0.1</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque><publish_odom>true</publish_odom>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin name="gazebo_ros_joint_pose_trajectory" filename="libgazebo_ros_joint_pose_trajectory.so">
      <ros>
        <remapping>set_joint_trajectory:=set_joint_angles</remapping>
      </ros>
      <update_rate>20</update_rate>
    </plugin>
  </gazebo>
  <link name="support_post">
    <visual><geometry><cylinder length="0.1" radius="0.02"/></geometry><material name="grey"><color rgba="0.5 0.5 0.5 1"/></material></visual>
    <inertial><mass value="0.1"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="post_joint" type="fixed">
    <parent link="base_link"/><child link="support_post"/><origin xyz="0 0 0.1"/>
  </joint>

  <link name="pan_link">
    <visual><geometry><box size="0.05 0.05 0.05"/></geometry><material name="black"><color rgba="0 0 0 1"/></material></visual>
    <inertial><mass value="0.1"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="pan_joint" type="revolute">
    <parent link="support_post"/><child link="pan_link"/><origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/> <limit lower="-1.57" upper="1.57" effort="1.0" velocity="1.0"/>
  </joint>

  <link name="tilt_link">
    <visual><geometry><box size="0.06 0.04 0.03"/></geometry><material name="red"><color rgba="1 0 0 1"/></material></visual>
    <inertial><mass value="0.1"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="tilt_joint" type="revolute">
    <parent link="pan_link"/><child link="tilt_link"/><origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/> <limit lower="-1.0" upper="1.0" effort="1.0" velocity="1.0"/>
  </joint>

  <gazebo>
    <plugin name="gazebo_ros_joint_pose_trajectory" filename="libgazebo_ros_joint_pose_trajectory.so">
      <ros>
        <remapping>set_joint_trajectory:=set_joint_angles</remapping>
      </ros>
      <update_rate>20</update_rate>
    </plugin>
  </gazebo>
</robot>
